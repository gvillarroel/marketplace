{
  "name": "@gvillarroel/agent-harbor",
  "version": "0.12.1",
  "description": "Agent Harbor plugins for GitHub Copilot CLI, OpenCode, and Pi",
  "type": "module",
  "main": "./dist/adapters/opencode.js",
  "exports": {
    ".": "./dist/adapters/opencode.js",
    "./server": "./dist/adapters/opencode.js",
    "./tui": "./dist/adapters/opencode-tui.js",
    "./core": "./dist/core/commands.js",
    "./pi": "./dist/adapters/pi.js"
  },
  "bin": {
    "agent-harbor": "./dist/cli.js"
  },
  "files": [
    "docs/",
    "dist/",
    "plugins/",
    "scripts/asciinema-demo.mjs",
    "scripts/asciinema-copilot-tui.py",
    "scripts/asciinema-copilot-tui-win.py",
    "scripts/asciinema_capture_common.py",
    "scripts/publish-asciinema-assets.py",
    "scripts/run-capture-tests.mjs",
    "scripts/verify-packaged-capture.mjs",
    "scripts/copilot-extension-permission-gate.mjs",
    "scripts/asciinema-replay.mjs",
    "tests/test_asciinema_capture_common.py",
    "tests/test_asciinema_copilot_tui_posix.py",
    "tests/test_asciinema_copilot_tui_win.py"
  ],
  "engines": {
    "node": ">=22.19.0",
    "opencode": ">=1.18.3"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "node scripts/run-tests.mjs",
    "test:capture": "node scripts/run-capture-tests.mjs",
    "test:capture:package": "node scripts/verify-packaged-capture.mjs",
    "typecheck": "tsc --noEmit",
    "test:ts": "node scripts/run-test-suite.mjs",
    "test:live:lead": "node scripts/run-live-lead.mjs",
    "test:live:opencode": "node scripts/run-live-codex-leads.mjs opencode",
    "test:live:pi": "node scripts/run-live-codex-leads.mjs pi",
    "test:live:codex": "node scripts/run-live-codex-leads.mjs all",
    "test:installed:copilot": "node scripts/verify-installed-copilot.mjs",
    "test:installed:copilot:smoke": "node scripts/verify-installed-copilot.mjs --smoke",
    "demo:commands": "node scripts/asciinema-demo.mjs",
    "prepack": "npm run build"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "pi-package",
    "agents",
    "skills"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gvillarroel/marketplace.git"
  },
  "license": "MIT",
  "pi": {
    "extensions": [
      "./dist/adapters/pi.js"
    ]
  },
  "dependencies": {
    "@github/copilot-sdk": "1.0.6",
    "@opencode-ai/plugin": "1.18.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.10 || 0.81.1"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
